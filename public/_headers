# Segurança — aplicada a todas as páginas
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://accounts.google.com; font-src 'self' https://fonts.gstatic.com data:; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob: https://www.googletagmanager.com https://cdn.jsdelivr.net https://accounts.google.com; worker-src 'self' blob:; connect-src 'self' https://cdn.jsdelivr.net https://*.google-analytics.com https://*.googletagmanager.com https://*.analytics.google.com https://accounts.google.com https://huggingface.co https://*.hf.co https://cdn-lfs.huggingface.co https://*.xethub.hf.co; frame-src https://www.google.com https://maps.google.com https://www.youtube.com https://www.youtube-nocookie.com https://accounts.google.com; frame-ancestors 'self'; base-uri 'self'; object-src 'none'; form-action 'self'

# Painel admin e APIs: nunca indexar
/admin
  X-Robots-Tag: noindex, nofollow

/api/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

# Páginas personalizadas de cliente: privadas, nunca indexar
/cliente/*
  X-Robots-Tag: noindex, nofollow

# Áreas privadas / pessoais: nunca indexar
/painel
  X-Robots-Tag: noindex, nofollow
/conta
  X-Robots-Tag: noindex, nofollow
/favoritos
  X-Robots-Tag: noindex, nofollow

# Cache das imagens de imóveis: 1h no navegador, depois revalida (pega versão nova rápido).
# Evita que uma foto trocada fique "presa" desfocada no cache do visitante.
/imoveis/*
  Cache-Control: public, max-age=3600, must-revalidate

# Assets com hash no nome: imutáveis (novo hash = novo arquivo)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Catálogo de imóveis: 30 min, serve stale enquanto revalida
/catalogo.json
  Cache-Control: public, max-age=1800, stale-while-revalidate=3600

# Imagens e ícones estáticos na raiz
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=604800
/*.jpg
  Cache-Control: public, max-age=604800
